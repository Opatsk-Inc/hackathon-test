# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=levtrans

# Constructed automatically in docker-compose from above ↑
# For local development outside Docker set this manually:
DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5432/levtrans

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
# Constructed automatically in docker-compose:
REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ─── NestJS Server ────────────────────────────────────────────────────────────
PORT=1488
JWT_SECRET=change_me_jwt_secret_min_32_chars
EXPIRATION_TIME=7d

# ─── Vite Client (baked in at build time) ────────────────────────────────────
VITE_API_URL=https://api.levtrans.notfounds.dev
