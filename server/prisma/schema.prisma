generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WAREHOUSE_MANAGER
  DISPATCHER
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  passwordHash     String
  firstName        String?
  lastName         String?
  role             Role     @default(WAREHOUSE_MANAGER)
  registrationDate DateTime @default(dbgenerated("timezone('UTC'::text, now())")) @db.Timestamp(6)

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  @@map("user")
}

model Warehouse {
  id        String      @id @default(uuid())
  name      String
  address   String?
  lat       Float
  lng       Float
  users     User[]
  inventory Inventory[]
  ordersOut Order[]     @relation("Requester")
  ordersIn  Order[]     @relation("Provider")

  @@map("warehouse")
}

model Resource {
  id        String      @id @default(uuid())
  name      String
  category  String?
  inventory Inventory[]
  orders    Order[]

  @@map("resource")
}

model Inventory {
  id                String    @id @default(uuid())
  quantityAvailable Int       @default(0)
  quantityReserved  Int       @default(0)
  warehouseId       String
  resourceId        String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id])
  resource          Resource  @relation(fields: [resourceId], references: [id])

  @@unique([warehouseId, resourceId])
  @@map("inventory")
}

enum Priority {
  NORMAL
  HIGH
  CRITICAL
}

enum OrderStatus {
  PENDING
  APPROVED
  PACKED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(uuid())
  quantity    Int
  priority    Priority    @default(NORMAL)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  requesterId String
  providerId  String?
  resourceId  String
  requester   Warehouse   @relation("Requester", fields: [requesterId], references: [id])
  provider    Warehouse?  @relation("Provider", fields: [providerId], references: [id])
  resource    Resource    @relation(fields: [resourceId], references: [id])
  trip        Trip?

  @@map("order")
}

enum TripStatus {
  PENDING
  EN_ROUTE
  DELIVERED
  SOS
}

model Trip {
  id         String      @id @default(uuid())
  magicToken String      @unique @default(uuid())
  status     TripStatus  @default(PENDING)
  driverName String?
  currentLat Float?
  currentLng Float?
  orderId    String      @unique
  order      Order       @relation(fields: [orderId], references: [id])
  points     TripPoint[]

  @@map("trip")
}

model TripPoint {
  id        String   @id @default(uuid())
  tripId    String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("trip_point")
}
