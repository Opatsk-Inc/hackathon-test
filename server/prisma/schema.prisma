generator client {
  provider     = "prisma-client-js"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WAREHOUSE_MANAGER
  DISPATCHER
}

model EmailChange {
  token      String   @id @db.Char(21)
  newEmail   String
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  validUntil DateTime @default(dbgenerated("(timezone('utc'::text, now()) + '2 days'::interval)")) @db.Timestamp(6)

  @@map("email-change")
}

model EmailVerification {
  token      String   @id @db.Char(21)
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  validUntil DateTime @default(dbgenerated("(timezone('utc'::text, now()) + '2 days'::interval)")) @db.Timestamp(6)

  @@map("email-verification")
}

model PasswordReset {
  token      String   @id @db.Char(21)
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  validUntil DateTime @default(dbgenerated("(timezone('utc'::text, now()) + '2 days'::interval)")) @db.Timestamp(6)

  @@map("password-reset")
}

model User {
  id                Int                @id @default(autoincrement())
  username          String             @unique
  email             String             @unique
  passwordHash      String
  firstName         String
  lastName          String
  middleName        String?
  image             String?
  emailVerified     Boolean            @default(false)
  role              Role               @default(WAREHOUSE_MANAGER)
  birthDate         DateTime?          @db.Date
  registrationDate  DateTime           @default(dbgenerated("timezone('UTC'::text, now())")) @db.Timestamp(6)
  emailChange       EmailChange?
  emailVerification EmailVerification?
  passwordReset     PasswordReset?

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  @@map("user")
}

model Warehouse {
  id        String      @id @default(uuid())
  name      String
  address   String?
  lat       Float
  lng       Float
  users     User[]
  inventory Inventory[]
  ordersOut Order[]     @relation("Requester")
  ordersIn  Order[]     @relation("Provider")
}

model Resource {
  id        String      @id @default(uuid())
  name      String
  category  String?
  inventory Inventory[]
  orders    Order[]
}

model Inventory {
  id                String    @id @default(uuid())
  quantityAvailable Int       @default(0)
  quantityReserved  Int       @default(0)
  warehouseId       String
  resourceId        String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id])
  resource          Resource  @relation(fields: [resourceId], references: [id])

  @@unique([warehouseId, resourceId])
}

enum Priority {
  NORMAL
  HIGH
  CRITICAL
}

enum OrderStatus {
  PENDING
  APPROVED
  PACKED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(uuid())
  quantity    Int
  priority    Priority    @default(NORMAL)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  requesterId String
  providerId  String?
  resourceId  String
  requester   Warehouse   @relation("Requester", fields: [requesterId], references: [id])
  provider    Warehouse?  @relation("Provider", fields: [providerId], references: [id])
  resource    Resource    @relation(fields: [resourceId], references: [id])
  trip        Trip?
}

enum TripStatus {
  PENDING
  EN_ROUTE
  DELIVERED
  SOS
}

model Trip {
  id         String     @id @default(uuid())
  magicToken String     @unique @default(uuid())
  status     TripStatus @default(PENDING)
  driverName String?
  currentLat Float?
  currentLng Float?
  orderId    String     @unique
  order      Order      @relation(fields: [orderId], references: [id])
}
