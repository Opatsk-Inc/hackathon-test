{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2017",
    "sourceMap": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "outDir": "./dist",
    "incremental": true,
    "allowJs": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "prisma/generated"
  ]
}